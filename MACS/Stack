
    public static  class STACK{
     public  class Node{
        int data;
        Node next;
        Node(int data){
            this.data=data;
            this.next=null;
        }
    }

     Node head;

     public  void push(int data){
        if(head==null){
            Node temp=new Node(data);
            head=temp;
            return ;

        }
            Node temp=new Node(data);
            temp.next=head;
            head=temp;

    }

       public  int pop() {
    if (head == null) return -1;          
    if (head.next == null) {   
        int ans=head.data;
        head=null;             
      return ans;
    }
        Node temp = head;
                                                 
         head = head.next;                      
         temp.next = null;                       
         return temp.data;                           
}


    public  int peek(){
        return head.data;
    }



    public  boolean empty(){
        return head==null;
    }
    }

    public static void main(String[] args) {
       STACK s = new STACK();
      
        for (int i = 0; i <  10; i++) {
            s.push(i);
            }


        while (!s.empty()) {
            System.out.print(s.pop()+"  ");
        }


        
    }
