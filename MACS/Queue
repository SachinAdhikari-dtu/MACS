 public static  class  queue{



        /*
        Time complexity of all operation 
        
        - offer → O(1)
        -  poll → O(1)
        - peek → O(1)
        - empty → O(1)
        - size → O(n)
                    */


        
     public  class Node{
        int data;
        Node next;
        Node(int data){
            this.data=data;
            this.next=null;
        }
    }

     Node head;
     Node tail;
     public  void offer(int data){
        if(head==null){
            Node temp=new Node(data);
            tail=head=temp;
            return ;

        }
            Node temp=new Node(data);
            tail.next=temp;
            tail=temp;

    }

       public  int poll() {
    if (head == null) return -1;          
    if (head.next == null) {   
        int ans=head.data;
        tail=head=null;             
      return ans;
    }
        Node temp = head;
                                                 
         head = head.next;                      
         temp.next = null;                       
         return temp.data;                           
}


    public  int peek(){
        return head.data;
    }



    public  boolean empty(){
        return head==null;
    }



    public int size(){
        int ans=0;
        Node temp=head;
        while (temp!=null) {
            ans++;
            temp=temp.next;
        }return ans;
    }

    }

    public static void main(String[] args) {
       queue q= new queue();
      
        for (int i = 0; i <  10; i++) {
            q.offer(i);
            }

        System.out.println(q.peek());
        System.out.println(q.size());

        while (!q.empty()) {
            System.out.print(q.poll()+"  ");
        }


        
    }


